# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC-generated files
*.pdb

# macOS
.DS_Store
Thumbs.db

# IDE files
.idea/
.vscode/
*.swp
*.swo

# Dataset files (generated, not source code)
datasets/benchmark/*.json
datasets/debug/*.json

# Keep directory structure but ignore JSON files
!datasets/benchmark/.gitkeep
!datasets/debug/.gitkeep

# Output files
output/runs/**/*
output/profiles/**/*
output/reports/**/*

# Keep directory structure
!output/runs/.gitkeep
!output/profiles/.gitkeep
!output/reports/.gitkeep